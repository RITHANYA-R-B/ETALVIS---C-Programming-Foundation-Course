// Get a number and interchange the first and the last digit using function (with a return value)
#include<stdio.h>
int disp_interchange_first_last_digit(int x);
int main(){
    int x;
    scanf("%d",&x);
    int n=disp_interchange_first_last_digit(x);
    printf("%d",n);
    return 0;
}
int disp_interchange_first_last_digit(int x){
   int i=x,p=1;
    for(;x>=10;x=x/10)
        p=10*p;
    int n = x+(i%10)*p+((i/10)%(p/10))*10;
    return n;
}
