// Get a number, if its last digit is even print the number, else subtract one from the first digit and print it using function (with a return value)
#include<stdio.h>
int check_last_digit_odd(int x);
int main(){
    int x;
    scanf("%d",&x);
    int n=check_last_digit_odd(x);
    printf("%d",n);
    return 0;
}
int check_last_digit_odd(int x){
    int i=x,p=1,n;
    for(;x>=10;x=x/10)
        p=10*p;
    if((i%10)%2==0)
        n=i;
    else
        n=i%p+(x-1)*p;
    return n;
}
