// Print whether prime or not AND the sum of digits is 14 or not (using functions)
#include<stdio.h>
void check_prime_and_sum14(int x);
int main(){
    int x;
    scanf("%d",&x);
    check_prime_and_sum14(x);
    return 0;
}
void check_prime_and_sum14(int x){
    int i=2,n=0;
    while(i<=x/2){
        if(x%i==0)
            n++;
            i++;
    }
    int p=x,sum=0;
    while(p>0){
    sum=sum+p%10;
    p=p/10;
    }
    if(n==0 && x>1){
    if(sum==14)
    printf("Prime & Sum of digits is 14.");
    else
    printf("Prime & Sum of digits is not 14.");
    }
    else{
    if(sum==14)
    printf("Not Prime but Sum of digits is 14.");
    else
    printf("Not Prime & Sum of digits is not 14.");
    }
}
