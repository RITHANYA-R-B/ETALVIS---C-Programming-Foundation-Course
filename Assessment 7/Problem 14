// Get a number and interchange the first and the last digit (using functions)
#include<stdio.h>
void disp_interchange_first_last_digit(int x);
int main(){
    int x;
    scanf("%d",&x);
    disp_interchange_first_last_digit(x);
    return 0;
}
void disp_interchange_first_last_digit(int x){
    int i=x,p=1;
    for(;x>=10;x=x/10){
        p=10*p;
    }
    printf("%d",x+(i%10)*p+((i/10)%(p/10))*10);
}
